    "num = 5\n",
    "def factorial(num):\n",
    "  if num == 0 or num == 1:\n",
    "    return 1\n",
    "  else:\n",
    "    return num * factorial(num-1)\n",
    "print(factorial(num))\n",
    "  "
   ]
